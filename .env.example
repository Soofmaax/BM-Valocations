# Frontend (Vite + React)
VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production

# Region Zoho (EU par défaut)
VITE_ZOHO_REGION=eu

# Zoho SalesIQ (widget code depuis l'interface SalesIQ)
VITE_ZOHO_SALESIQ_WIDGET_CODE=

# Analytics (au choix)
VITE_PLAUSIBLE_DOMAIN=yourdomain.com
VITE_GA4_ID=G-XXXXXXXX
VITE_CLARITY_ID=XXXXXXXX

# API Serverless (Zoho CRM OAuth2 via refresh token)
ZOHO_BASE=https://www.zohoapis.eu
ZOHO_ACCOUNTS=https://accounts.zoho.eu
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Sanity Studio (facultatif, pour sanity/sanity.config.ts)
SANITY_PROJECT_ID=your_sanity_project_id
SANITY_DATASET=production
SANITY_READ_TOKEN=
SANITY_WEBHOOK_SECRET=