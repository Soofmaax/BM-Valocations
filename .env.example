# Frontend (Vite) public variables
# Replace values and copy to your deployment environment (Vercel/Netlify) and local .env
# Example for JSON public data (GitHub raw URL to your citadines.json)
VITE_CITADINES_URL="https://raw.githubusercontent.com/your-org/your-repo/main/citadines.json"

# Supabase (required for Edge Function calls authentication)
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# Edge Functions (server) secrets are set on Supabase, NOT here:
# ADMIN_EMAIL, RESEND_API_KEY, RESEND_FROM